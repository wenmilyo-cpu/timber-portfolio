<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Timber Goodboy — Partnership Portfolio</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Fredoka:wght@500;600;700&family=Work+Sans:wght@400;500;600;700&family=JetBrains+Mono:wght@500;700&display=swap" rel="stylesheet">
<style>
  :root{
    --cream: #FFF6E8;
    --ink: #1F2A24;
    --coral: #FF6B4A;
    --grass: #3D8361;
    --mustard: #F2B705;
    --sky: #4A90A4;
    --card-bg: #FFFFFF;
    --dash: #C9BFA8;
  }

  *{ box-sizing:border-box; margin:0; padding:0; }

  html{ scroll-behavior:smooth; }

  body{
    background:var(--cream);
    color:var(--ink);
    font-family:'Work Sans', sans-serif;
    line-height:1.5;
    overflow-x:hidden;
  }

  h1,h2,h3, .display{
    font-family:'Fredoka', sans-serif;
    font-weight:600;
    letter-spacing:-0.01em;
  }

  .mono{
    font-family:'JetBrains Mono', monospace;
  }

  a{ color:inherit; }

  .wrap{
    max-width:1100px;
    margin:0 auto;
    padding:0 32px;
  }

  /* ---------- Background paw texture ---------- */
  .paw-bg{
    position:fixed;
    inset:0;
    z-index:0;
    pointer-events:none;
    opacity:0.05;
    background-image:
      radial-gradient(circle 5px at 10% 15%, var(--ink) 98%, transparent 100%),
      radial-gradient(circle 5px at 85% 8%, var(--ink) 98%, transparent 100%),
      radial-gradient(circle 5px at 60% 40%, var(--ink) 98%, transparent 100%),
      radial-gradient(circle 5px at 25% 70%, var(--ink) 98%, transparent 100%),
      radial-gradient(circle 5px at 92% 60%, var(--ink) 98%, transparent 100%),
      radial-gradient(circle 5px at 45% 90%, var(--ink) 98%, transparent 100%);
    background-size:100% 100%;
  }

  /* ---------- Nav ---------- */
  nav{
    position:sticky;
    top:0;
    z-index:50;
    background:rgba(255,246,232,0.9);
    backdrop-filter: blur(6px);
    border-bottom:2px solid var(--ink);
  }
  nav .wrap{
    display:flex;
    align-items:center;
    justify-content:space-between;
    padding-top:16px;
    padding-bottom:16px;
  }
  .nav-brand{
    font-family:'Fredoka', sans-serif;
    font-weight:700;
    font-size:1.15rem;
    display:flex;
    align-items:center;
    gap:8px;
  }
  .nav-brand .dot{
    width:10px; height:10px; border-radius:50%;
    background:var(--coral);
    display:inline-block;
  }
  nav .links{
    display:flex;
    gap:28px;
    font-size:0.92rem;
    font-weight:600;
  }
  nav .links a{
    text-decoration:none;
    border-bottom:2px solid transparent;
    padding-bottom:2px;
    transition:border-color 0.2s ease;
  }
  nav .links a:hover{ border-color:var(--coral); }

  @media (max-width:640px){
    nav .links{ display:none; }
  }

  /* ---------- Hero ---------- */
  header.hero{
    position:relative;
    z-index:1;
    padding:72px 0 56px;
    overflow:hidden;
  }
  .hero-grid{
    display:grid;
    grid-template-columns:1.1fr 0.9fr;
    gap:48px;
    align-items:center;
  }
  @media (max-width:820px){
    .hero-grid{ grid-template-columns:1fr; }
  }
  .eyebrow{
    display:inline-flex;
    align-items:center;
    gap:8px;
    background:var(--ink);
    color:var(--cream);
    font-family:'JetBrains Mono', monospace;
    font-size:0.78rem;
    font-weight:700;
    letter-spacing:0.04em;
    padding:7px 14px 7px 10px;
    border-radius:100px;
    margin-bottom:22px;
  }
  .eyebrow .paw{ font-size:0.95rem; }

  .hero h1{
    font-size:clamp(2.8rem, 6.5vw, 4.6rem);
    line-height:0.98;
    color:var(--ink);
  }
  .hero h1 span{ color:var(--coral); }

  .hero p.lead{
    margin-top:20px;
    font-size:1.15rem;
    max-width:480px;
    color:#3a4640;
  }

  .stat-row{
    display:flex;
    gap:28px;
    margin-top:32px;
    flex-wrap:wrap;
  }
  .stat{
    background:var(--card-bg);
    border:2px solid var(--ink);
    border-radius:16px;
    padding:14px 20px;
    box-shadow:4px 4px 0 var(--ink);
  }
  .stat .num{
    font-family:'JetBrains Mono', monospace;
    font-weight:700;
    font-size:1.5rem;
    color:var(--grass);
  }
  .stat .lbl{
    font-size:0.78rem;
    text-transform:uppercase;
    letter-spacing:0.06em;
    color:#6b6252;
    margin-top:2px;
  }

  .hero-photo{
    position:relative;
  }
  .photo-frame{
    aspect-ratio:1/1;
    border-radius:28px;
    border:3px dashed var(--dash);
    background:repeating-linear-gradient(135deg, #fffdf9, #fffdf9 12px, #fbf1de 12px, #fbf1de 24px);
    display:flex;
    align-items:center;
    justify-content:center;
    flex-direction:column;
    gap:10px;
    color:#8a7d63;
    text-align:center;
    padding:24px;
    position:relative;
    transform:rotate(-2deg);
  }
  .photo-frame .icon{ font-size:2.6rem; }
  .photo-frame .cap{ font-size:0.85rem; font-weight:600; }
  .photo-frame .sub{ font-size:0.75rem; color:#a89a7c; }

  .stamp{
    position:absolute;
    top:-18px;
    right:-14px;
    width:104px;
    height:104px;
    border-radius:50%;
    background:var(--mustard);
    border:3px solid var(--ink);
    display:flex;
    align-items:center;
    justify-content:center;
    transform:rotate(12deg);
    text-align:center;
    font-family:'Fredoka', sans-serif;
    font-weight:700;
    font-size:0.68rem;
    line-height:1.1;
    letter-spacing:0.02em;
    color:var(--ink);
    box-shadow:3px 3px 0 var(--ink);
  }

  /* ---------- Section headers ---------- */
  .section{
    position:relative;
    z-index:1;
    padding:64px 0;
  }
  .section-head{
    display:flex;
    align-items:baseline;
    justify-content:space-between;
    gap:20px;
    margin-bottom:36px;
    flex-wrap:wrap;
  }
  .section-head h2{
    font-size:clamp(1.9rem, 3.6vw, 2.6rem);
  }
  .section-head .note{
    font-family:'JetBrains Mono', monospace;
    font-size:0.82rem;
    color:#7a7160;
    max-width:280px;
  }

  /* ---------- About ---------- */
  .about{
    background:var(--card-bg);
    border:2px solid var(--ink);
    border-radius:24px;
    padding:40px;
    display:grid;
    grid-template-columns:auto 1fr;
    gap:32px;
    align-items:center;
    box-shadow:6px 6px 0 var(--ink);
  }
  @media (max-width:640px){
    .about{ grid-template-columns:1fr !important; text-align:center; }
    .about .about-photo{ margin:0 auto; }
  }
  .about-photo{
    width:140px;
    height:140px;
    border-radius:50%;
    border:3px dashed var(--dash);
    display:flex;
    align-items:center;
    justify-content:center;
    text-align:center;
    font-size:0.72rem;
    color:#a89a7c;
    padding:10px;
    flex-shrink:0;
  }
  .about p{ font-size:1.02rem; color:#3a4640; }
  .about .tags{
    margin-top:16px;
    display:flex;
    gap:10px;
    flex-wrap:wrap;
  }
  .tag{
    font-family:'JetBrains Mono', monospace;
    font-size:0.75rem;
    font-weight:700;
    background:var(--sky);
    color:#fff;
    padding:6px 12px;
    border-radius:100px;
  }

  /* ---------- Partnership grid ---------- */
  .cat-group{
    margin-bottom:48px;
  }
  .cat-group:last-child{ margin-bottom:0; }

  .cat-head{
    display:flex;
    align-items:center;
    gap:12px;
    margin-bottom:20px;
    padding-bottom:10px;
    border-bottom:2px solid var(--ink);
  }
  .cat-icon{
    font-size:1.3rem;
  }
  .cat-head h3{
    font-size:1.3rem;
    flex:1;
  }
  .cat-count{
    font-family:'JetBrains Mono', monospace;
    font-size:0.75rem;
    font-weight:700;
    background:var(--ink);
    color:var(--cream);
    padding:3px 10px;
    border-radius:100px;
  }

  .grid{
    display:grid;
    grid-template-columns:repeat(auto-fit, minmax(280px, 1fr));
    gap:26px;
  }

  .card{
    background:var(--card-bg);
    border:2px solid var(--ink);
    border-radius:20px;
    overflow:hidden;
    display:flex;
    flex-direction:column;
    transition:transform 0.18s ease, box-shadow 0.18s ease;
    box-shadow:5px 5px 0 var(--ink);
  }
  .card:hover{
    transform:translate(-3px,-3px);
    box-shadow:8px 8px 0 var(--ink);
  }

  .card-embed{
    padding:14px 14px 16px;
    border-bottom:2px solid var(--ink);
    background:#fafafa;
    display:flex;
    flex-direction:column;
    align-items:center;
    gap:10px;
  }
  .card-embed iframe{
    border-radius:12px;
    display:block;
  }
  .ig-link{
    font-family:'JetBrains Mono', monospace;
    font-size:0.8rem;
    font-weight:700;
    color:var(--coral);
    text-decoration:none;
    border-bottom:2px solid var(--coral);
    padding-bottom:1px;
    transition:opacity 0.15s ease;
  }
  .ig-link:hover{ opacity:0.7; }

  .card-photo{
    aspect-ratio:4/3;
    border-bottom:2px solid var(--ink);
    background:repeating-linear-gradient(135deg, #fffdf9, #fffdf9 10px, #fbf1de 10px, #fbf1de 20px);
    display:flex;
    align-items:center;
    justify-content:center;
    flex-direction:column;
    gap:6px;
    color:#a89a7c;
    text-align:center;
    padding:14px;
    position:relative;
  }
  .card-photo .icon{ font-size:1.8rem; }
  .card-photo .cap{ font-size:0.78rem; font-weight:600; }

  .ribbon{
    position:absolute;
    top:10px;
    left:10px;
    font-family:'JetBrains Mono', monospace;
    font-size:0.66rem;
    font-weight:700;
    background:var(--ink);
    color:var(--cream);
    padding:4px 9px;
    border-radius:100px;
    text-transform:uppercase;
    letter-spacing:0.03em;
  }

  .card-body{
    padding:20px 20px 22px;
    display:flex;
    flex-direction:column;
    gap:12px;
    flex:1;
  }
  .card-body h3{
    font-size:1.25rem;
    display:flex;
    align-items:center;
    gap:8px;
  }
  .card-body h3 .swatch{
    width:11px; height:11px; border-radius:50%;
    flex-shrink:0;
  }

  .placeholder-line{
    font-size:0.85rem;
    color:#8a7d63;
    border:1.5px dashed var(--dash);
    border-radius:10px;
    padding:8px 11px;
    font-family:'JetBrains Mono', monospace;
  }

  .metric-row{
    display:flex;
    gap:10px;
    flex-wrap:wrap;
    margin-top:auto;
  }
  .metric{
    flex:1;
    min-width:70px;
    border:1.5px dashed var(--dash);
    border-radius:10px;
    padding:8px 10px;
    text-align:center;
  }
  .metric .m-num{
    font-family:'JetBrains Mono', monospace;
    font-weight:700;
    font-size:0.95rem;
    color:#8a7d63;
  }
  .metric .m-lbl{
    font-size:0.62rem;
    text-transform:uppercase;
    letter-spacing:0.04em;
    color:#a89a7c;
    margin-top:2px;
  }

  /* ---------- Testimonial ---------- */
  .quote-block{
    background:var(--ink);
    color:var(--cream);
    border-radius:24px;
    padding:44px;
    position:relative;
    text-align:center;
  }
  .quote-block .mark{
    font-family:'Fredoka', sans-serif;
    font-size:3.5rem;
    color:var(--mustard);
    line-height:0.5;
    display:block;
    margin-bottom:12px;
  }
  .quote-block p{
    font-size:1.15rem;
    max-width:560px;
    margin:0 auto;
    font-style:italic;
    color:#f4ead4;
  }
  .quote-block .who{
    margin-top:18px;
    font-family:'JetBrains Mono', monospace;
    font-size:0.8rem;
    color:#c9bfa8;
  }

  /* ---------- Contact ---------- */
  .contact{
    background:var(--coral);
    border:2px solid var(--ink);
    border-radius:24px;
    padding:52px 40px;
    text-align:center;
    box-shadow:6px 6px 0 var(--ink);
  }
  .contact h2{
    color:var(--ink);
    font-size:clamp(1.9rem, 4vw, 2.6rem);
  }
  .contact p{
    margin-top:12px;
    color:#3a2018;
    font-size:1.02rem;
  }
  .contact .cta-row{
    margin-top:26px;
    display:flex;
    gap:16px;
    justify-content:center;
    flex-wrap:wrap;
  }
  .btn{
    font-family:'Fredoka', sans-serif;
    font-weight:600;
    font-size:0.98rem;
    padding:13px 26px;
    border-radius:100px;
    border:2px solid var(--ink);
    text-decoration:none;
    display:inline-flex;
    align-items:center;
    gap:8px;
    transition:transform 0.15s ease;
  }
  .btn:hover{ transform:translateY(-2px); }
  .btn-primary{
    background:var(--ink);
    color:var(--cream);
  }
  .btn-secondary{
    background:var(--cream);
    color:var(--ink);
  }

  footer{
    text-align:center;
    padding:34px 0 44px;
    font-family:'JetBrains Mono', monospace;
    font-size:0.78rem;
    color:#8a7d63;
    position:relative;
    z-index:1;
  }

  /* ---------- fade-in on scroll ---------- */
  .reveal{
    opacity:0;
    transform:translateY(18px);
    transition:opacity 0.6s ease, transform 0.6s ease;
  }
  .reveal.in{
    opacity:1;
    transform:translateY(0);
  }

  @media (prefers-reduced-motion: reduce){
    .reveal{ opacity:1; transform:none; transition:none; }
    html{ scroll-behavior:auto; }
  }

  :focus-visible{
    outline:3px solid var(--sky);
    outline-offset:3px;
  }
</style>
</head>
